# Email Configuration for MediConnect
# Copy this file to .env and fill in your details

# Gmail account to send emails from
GMAIL_USER=your-email@gmail.com

# Gmail App Password (16 characters, no spaces)
# Get it from: Google Account → Security → 2-Step Verification → App passwords
GMAIL_PASSWORD=your-app-password-here

# Base URL for links in emails (change in production)
BASE_URL=http://localhost:5000

# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your Gmail credentials
# 3. Restart Flask server
# 4. Emails will start sending automatically!

# How to get Gmail App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to App passwords
# 4. Select "Mail" and "Other (Custom name)"
# 5. Enter "MediConnect" as name
# 6. Copy the 16-character password
# 7. Paste it above (no spaces)
